---

<div class="phone" data-animate="fade-up" data-delay="0.2">
  <div class="phone-frame">
    <div class="phone-notch"></div>
    <div class="phone-screen">
      <!-- Simulated app UI -->
      <div class="app">
        <div class="app-nav">
          <div class="app-back"></div>
          <span class="app-title">Shadow Monarch</span>
          <div class="app-dots"></div>
        </div>

        <div class="app-content">
          <div class="app-line w100"></div>
          <div class="app-line w90"></div>
          <div class="app-line w95"></div>
          <div class="app-line w80"></div>
          <div class="app-line w100"></div>
          <div class="app-line w85"></div>
          <div class="app-line w92"></div>
          <div class="app-line w70"></div>
          <div class="app-line w100"></div>
          <div class="app-line w88"></div>
          <div class="app-line w95"></div>
          <div class="app-line w60"></div>
          <div class="app-line w100"></div>
          <div class="app-line w90"></div>
          <div class="app-line w82"></div>
          <div class="app-line w100"></div>
          <div class="app-line w75"></div>
          <div class="app-line w93"></div>
        </div>

        <div class="app-bottom">
          <div class="app-progress"></div>
          <span class="app-page">3 / 12</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .phone {
    flex-shrink: 0;
  }

  .phone-frame {
    position: relative;
    width: 260px;
    height: 520px;
    border-radius: 40px;
    border: 3px solid rgba(255, 255, 255, 0.12);
    background: #0a0a0e;
    padding: 12px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 24px;
    background: #0a0a0e;
    border-radius: 0 0 16px 16px;
    z-index: 2;
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 28px;
    overflow: hidden;
    background: #111116;
  }

  /* Simulated app */
  .app {
    height: 100%;
    display: flex;
    flex-direction: column;
    font-family: var(--font);
  }

  .app-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 36px 16px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .app-back {
    width: 8px;
    height: 8px;
    border-left: 2px solid var(--text-secondary);
    border-bottom: 2px solid var(--text-secondary);
    transform: rotate(45deg);
  }

  .app-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .app-dots {
    width: 16px;
    height: 4px;
    background: radial-gradient(circle, var(--text-secondary) 1.5px, transparent 1.5px);
    background-size: 6px 4px;
  }

  .app-content {
    flex: 1;
    padding: 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
  }

  .app-line {
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.06);
    animation: shimmer 3s ease-in-out infinite;
  }

  .app-line:nth-child(4n + 1) {
    animation-delay: 0s;
  }
  .app-line:nth-child(4n + 2) {
    animation-delay: 0.3s;
  }
  .app-line:nth-child(4n + 3) {
    animation-delay: 0.6s;
  }
  .app-line:nth-child(4n) {
    animation-delay: 0.9s;
  }

  .w100 {
    width: 100%;
  }
  .w95 {
    width: 95%;
  }
  .w93 {
    width: 93%;
  }
  .w92 {
    width: 92%;
  }
  .w90 {
    width: 90%;
  }
  .w88 {
    width: 88%;
  }
  .w85 {
    width: 85%;
  }
  .w82 {
    width: 82%;
  }
  .w80 {
    width: 80%;
  }
  .w75 {
    width: 75%;
  }
  .w70 {
    width: 70%;
  }
  .w60 {
    width: 60%;
  }

  @keyframes shimmer {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }

  .app-bottom {
    padding: 10px 18px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .app-progress {
    flex: 1;
    height: 3px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
  }

  .app-progress::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 25%;
    background: var(--accent);
    border-radius: 2px;
  }

  .app-page {
    font-size: 10px;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 900px) {
    .phone-frame {
      width: 220px;
      height: 440px;
      border-radius: 32px;
      padding: 10px;
    }
    .phone-notch {
      width: 64px;
      height: 20px;
      top: 10px;
    }
    .phone-screen {
      border-radius: 22px;
    }
  }

  @media (max-width: 640px) {
    .phone {
      display: none;
    }
  }
</style>
