---
import Logo from './Logo.astro'
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <Logo size={20} />
      <span>Glyph</span>
    </div>
    <div class="footer-links">
      <a href="https://glyph.moe">glyph.moe</a>
      <a href="https://github.com/thinkaz/glyph" target="_blank" rel="noopener">GitHub</a>
      <a href="/docs">Docs</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
