---
interface Props {
  size?: number
}
const { size = 24 } = Astro.props
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class="glyph-logo"
>
  <polygon
    points="24,8 38,16 38,32 24,40 10,32 10,16"
    stroke="var(--logo-stroke, white)"
    stroke-width="2"
    fill="none"></polygon>
  <polygon
    points="24,14 33,19 33,29 24,34 15,29 15,19"
    stroke="var(--logo-stroke, white)"
    stroke-width="1"
    fill="none"
    opacity="0.4"></polygon>
  <line x1="24" y1="8" x2="24" y2="14" stroke="var(--logo-stroke, white)" stroke-width="1.5"></line>
  <line x1="24" y1="34" x2="24" y2="40" stroke="var(--logo-stroke, white)" stroke-width="1.5"
  ></line>
  <line x1="10" y1="16" x2="15" y2="19" stroke="var(--logo-stroke, white)" stroke-width="1.5"
  ></line>
  <line x1="38" y1="16" x2="33" y2="19" stroke="var(--logo-stroke, white)" stroke-width="1.5"
  ></line>
  <line x1="10" y1="32" x2="15" y2="29" stroke="var(--logo-stroke, white)" stroke-width="1.5"
  ></line>
  <line x1="38" y1="32" x2="33" y2="29" stroke="var(--logo-stroke, white)" stroke-width="1.5"
  ></line>
  <circle cx="24" cy="24" r="6" stroke="#FAC775" stroke-width="0.75" fill="none" opacity="0.35"
  ></circle>
  <circle cx="24" cy="24" r="3.5" fill="var(--accent, #EF9F27)"></circle>
</svg>
