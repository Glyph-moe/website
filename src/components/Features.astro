---
const features = [
  {
    id: 'extensions',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 3H12H8C6.34315 3 5 4.34315 5 6V18C5 19.6569 6.34315 21 8 21H11M13.5 3L19 8.625M13.5 3V7.625C13.5 8.17728 13.9477 8.625 14.5 8.625H19M19 8.625V11"/><path d="M17 15V18M17 21V18M17 18H14M17 18H20"/></svg>`,
    title: 'Extensions',
    description:
      'Community-built sources. Add any novel site with a simple TypeScript extension. Browse, search, and read from dozens of sources.',
  },
  {
    id: 'offline',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0l-4-4m4 4l4-4"/><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>`,
    title: 'Offline reading',
    description:
      'Download chapters for offline access. Read anywhere — on a plane, in the subway, or in bed with no connection.',
  },
  {
    id: 'privacy',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>`,
    title: 'Privacy first',
    description:
      'No accounts, no tracking, no ads. Your reading data stays on your device. Extensions run sandboxed with domain restrictions.',
  },
]
---

<section class="features" id="features">
  <div class="container features-layout">
    <div class="features-cards">
      {
        features.map((f, i) => (
          <div
            class="feature-card"
            data-feature={f.id}
            data-animate="fade-up"
            data-delay={String(i * 0.1)}
          >
            <div class="feature-icon" set:html={f.icon} />
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.description}</p>
          </div>
        ))
      }
    </div>

    <div class="phone-sticky">
      <div class="iphone">
        <div class="iphone-frame">
          <div class="dynamic-island"></div>
          <div class="iphone-screen">
            <!-- Screen: Extensions -->
            <div class="screen screen-extensions active" data-screen="extensions">
              <div class="s-nav"><span class="s-title">Browse</span></div>
              <div class="s-body">
                <div class="source-card">
                  <div class="source-icon"></div>
                  <div class="source-info">
                    <span class="source-name">Royal Road</span>
                    <span class="source-lang">EN</span>
                  </div>
                </div>
                <div class="source-card">
                  <div class="source-icon"></div>
                  <div class="source-info">
                    <span class="source-name">NovelFire</span>
                    <span class="source-lang">EN</span>
                  </div>
                </div>
                <div class="source-card">
                  <div class="source-icon"></div>
                  <div class="source-info">
                    <span class="source-name">Novelish Universe</span>
                    <span class="source-lang">EN</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Screen: Offline -->
            <div class="screen screen-offline" data-screen="offline">
              <div class="s-nav"><span class="s-title">Downloads</span></div>
              <div class="s-body">
                <div class="dl-item">
                  <div class="dl-cover"></div>
                  <div class="dl-info">
                    <span class="dl-name">Shadow Monarch</span>
                    <span class="dl-meta">142 chapters &middot; 24 MB</span>
                  </div>
                  <div class="dl-check">&#10003;</div>
                </div>
                <div class="dl-item">
                  <div class="dl-cover"></div>
                  <div class="dl-info">
                    <span class="dl-name">The Beginning After the End</span>
                    <span class="dl-meta">86 chapters &middot; 18 MB</span>
                  </div>
                  <div class="dl-check">&#10003;</div>
                </div>
                <div class="dl-item downloading">
                  <div class="dl-cover"></div>
                  <div class="dl-info">
                    <span class="dl-name">Omniscient Reader</span>
                    <div class="dl-progress"><div class="dl-bar"></div></div>
                  </div>
                  <span class="dl-pct">67%</span>
                </div>
              </div>
            </div>

            <!-- Screen: Privacy -->
            <div class="screen screen-privacy" data-screen="privacy">
              <div class="s-nav"><span class="s-title">Settings</span></div>
              <div class="s-body">
                <div class="pv-section">Filters &amp; Ratings</div>
                <div class="pv-row">
                  <span>Content Rating</span>
                  <span class="pv-value">Everyone</span>
                </div>
                <div class="pv-row">
                  <span>Blur Adult Covers</span>
                  <div class="pv-toggle on"></div>
                </div>
                <div class="pv-section">About</div>
                <div class="pv-row">
                  <span>iCloud Sync</span>
                  <span class="pv-value">Connected</span>
                </div>
                <div class="pv-row">
                  <span>Tracking</span>
                  <span class="pv-value accent">None</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .features {
    padding: 40px 0 120px;
  }

  .features-layout {
    display: flex;
    gap: 64px;
    align-items: flex-start;
  }

  .features-cards {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .feature-card {
    padding: 32px 28px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-surface);
    transition:
      border-color 0.3s,
      background 0.3s;
    cursor: pointer;
    scroll-margin-top: 40vh;
  }

  .feature-card.active {
    border-color: rgba(239, 159, 39, 0.25);
    background: var(--bg-surface-hover);
  }

  .feature-card:hover {
    border-color: rgba(255, 255, 255, 0.1);
    background: var(--bg-surface-hover);
  }

  .feature-icon {
    color: var(--accent);
    margin-bottom: 20px;
  }

  .feature-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .feature-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Phone sticky column */
  .phone-sticky {
    position: sticky;
    top: 120px;
    flex-shrink: 0;
  }

  /* iPhone mockup */
  .iphone-frame {
    position: relative;
    width: 272px;
    height: 556px;
    border-radius: 48px;
    border: 3px solid var(--phone-border, rgba(255, 255, 255, 0.1));
    background: var(--phone-body, #000);
    padding: 8px;
    box-shadow:
      inset 0 0 0 1px var(--phone-border-inner, rgba(255, 255, 255, 0.04)),
      0 24px 64px var(--phone-shadow, rgba(0, 0, 0, 0.6));
    transition:
      background 0.3s,
      border-color 0.3s,
      box-shadow 0.3s;
  }

  .dynamic-island {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 28px;
    background: var(--phone-body, #000);
    border-radius: 20px;
    z-index: 3;
    transition: background 0.3s;
  }

  .iphone-screen {
    width: 100%;
    height: 100%;
    border-radius: 40px;
    overflow: hidden;
    background: var(--phone-screen, #111116);
    position: relative;
    transition: background 0.3s;
  }

  /* Screens */
  .screen {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    display: flex;
    flex-direction: column;
  }

  .screen.active {
    opacity: 1;
  }

  .s-nav {
    padding: 52px 18px 12px;
    border-bottom: 1px solid var(--phone-surface-border);
  }

  .s-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--phone-text);
    letter-spacing: -0.02em;
  }

  .s-body {
    flex: 1;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
  }

  /* Extensions screen */
  .source-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px;
    border-radius: 12px;
    background: var(--phone-surface);
    border: 1px solid var(--phone-surface-border);
  }

  .source-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--phone-surface-border);
  }

  .source-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .source-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--phone-text);
  }

  .source-lang {
    font-size: 10px;
    color: var(--phone-text-secondary);
    letter-spacing: 0.05em;
  }

  /* Offline screen */
  .dl-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border-radius: 10px;
    background: var(--phone-surface);
  }

  .dl-cover {
    width: 32px;
    height: 44px;
    border-radius: 4px;
    background: var(--phone-surface-border);
    flex-shrink: 0;
  }

  .dl-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .dl-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--phone-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dl-meta {
    font-size: 10px;
    color: var(--phone-text-secondary);
  }

  .dl-check {
    font-size: 12px;
    color: #34c759;
    font-weight: 700;
  }

  .dl-progress {
    height: 3px;
    border-radius: 2px;
    background: var(--phone-surface-border);
    overflow: hidden;
  }

  .dl-bar {
    height: 100%;
    width: 67%;
    background: var(--accent);
    border-radius: 2px;
    animation: download 2s ease-in-out infinite;
  }

  @keyframes download {
    0% {
      width: 55%;
    }
    50% {
      width: 78%;
    }
    100% {
      width: 55%;
    }
  }

  .dl-pct {
    font-size: 10px;
    color: var(--accent);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  /* Privacy screen */
  .pv-section {
    font-size: 11px;
    font-weight: 600;
    color: var(--phone-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 8px 0 4px;
  }

  .pv-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 0;
    border-bottom: 1px solid var(--phone-surface-border);
    font-size: 13px;
    color: var(--phone-text);
  }

  .pv-value {
    font-size: 12px;
    color: var(--phone-text-secondary);
  }

  .pv-value.accent {
    color: var(--accent);
    font-weight: 600;
  }

  .pv-toggle {
    width: 40px;
    height: 24px;
    border-radius: 12px;
    background: var(--phone-surface-border);
    position: relative;
  }

  .pv-toggle.on {
    background: #34c759;
  }

  .pv-toggle::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    top: 2px;
    left: 2px;
    transition: transform 0.2s;
  }

  .pv-toggle.on::after {
    transform: translateX(16px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .features-layout {
      flex-direction: column;
      align-items: center;
    }
    .features-cards {
      order: 2;
    }
    .phone-sticky {
      position: relative;
      top: 0;
      order: 1;
      margin-bottom: 16px;
    }
    .iphone-frame {
      width: 240px;
      height: 490px;
      border-radius: 42px;
    }
    .iphone-screen {
      border-radius: 34px;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)

  const cards = document.querySelectorAll('.feature-card[data-feature]')
  const screens = document.querySelectorAll('.screen[data-screen]')

  function setActiveScreen(id: string) {
    screens.forEach(s => s.classList.toggle('active', s.getAttribute('data-screen') === id))
    cards.forEach(c => c.classList.toggle('active', c.getAttribute('data-feature') === id))
  }

  cards.forEach((card, i) => {
    // Each card activates when its top enters the center of the viewport
    // and stays active until the NEXT card enters that zone
    ScrollTrigger.create({
      trigger: card,
      start: 'top 65%',
      end: () => {
        const next = cards[i + 1] as HTMLElement | undefined
        if (next) {
          return `+=${next.offsetTop - (card as HTMLElement).offsetTop}`
        }
        return 'bottom top'
      },
      onToggle: ({ isActive }) => {
        if (isActive) setActiveScreen(card.getAttribute('data-feature')!)
      },
    })

    card.addEventListener('click', () => {
      setActiveScreen(card.getAttribute('data-feature')!)
    })
  })
</script>
