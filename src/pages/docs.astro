---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { getCollection } from 'astro:content'

const allDocs = await getCollection('docs')
const sorted = allDocs.sort((a, b) => a.data.order - b.data.order)
const appDocs = sorted.filter(d => d.data.order <= 2)
const sdkDocs = sorted.filter(d => d.data.order >= 3)

const descriptions: Record<string, string> = {
  'getting-started': 'How to use the app, add extensions, browse novels, and customize the reader.',
  faq: 'Common questions about Glyph, extensions, privacy, and troubleshooting.',
  'sdk-overview': 'Architecture, quick start, project structure, and createSource basics.',
  'sdk-source-interface': 'Required and optional methods, types, and full examples.',
  'sdk-http': 'get, post, json, rate limiting, retries, interceptors, and error handling.',
  'sdk-helpers': 'Cheerio HTML parsing, pagination, cookies, and content rating.',
  'sdk-publishing': 'Building, hosting, versioning, testing, and deep links.',
  'sdk-debugging':
    'Network inspector, app logs, console logging, common errors, and dev server tips.',
}

const icons: Record<string, string> = {
  'getting-started':
    '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  faq: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
  'sdk-overview':
    '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
  'sdk-source-interface':
    '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  'sdk-http':
    '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
  'sdk-helpers':
    '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
  'sdk-publishing':
    '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>',
  'sdk-debugging':
    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bug-icon lucide-bug"><path d="M12 20v-9"/><path d="M14 7a4 4 0 0 1 4 4v3a6 6 0 0 1-12 0v-3a4 4 0 0 1 4-4z"/><path d="M14.12 3.88 16 2"/><path d="M21 21a4 4 0 0 0-3.81-4"/><path d="M21 5a4 4 0 0 1-3.55 3.97"/><path d="M22 13h-4"/><path d="M3 21a4 4 0 0 1 3.81-4"/><path d="M3 5a4 4 0 0 0 3.55 3.97"/><path d="M6 13H2"/><path d="m8 2 1.88 1.88"/><path d="M9 7.13V6a3 3 0 1 1 6 0v1.13"/></svg>',
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Glyph Documentation" />
    <meta name="theme-color" content="#0E0E12" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Documentation — Glyph</title>
    <script is:inline>
      ;(function () {
        var t = localStorage.getItem('theme')
        if (t) document.documentElement.setAttribute('data-theme', t)
      })()
    </script>
  </head>
  <body>
    <Nav />

    <main class="docs-index">
      <div class="container">
        <div class="docs-hero">
          <h1>Documentation</h1>
          <p>Everything you need to use Glyph and build extensions.</p>
        </div>

        <section class="docs-section">
          <h2>Using Glyph</h2>
          <div class="docs-grid">
            {
              appDocs.map(doc => (
                <a href={`/docs/${doc.id}`} class="doc-card">
                  <span class="doc-icon" set:html={icons[doc.id] || ''} />
                  <div class="doc-card-content">
                    <h3>{doc.data.title}</h3>
                    <p>{descriptions[doc.id] || ''}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </section>

        <section class="docs-section">
          <h2>Extension SDK</h2>
          <p class="section-desc">
            Build your own extensions with the <code>@glyph/sdk</code>. Start with the
            <a href="/template/example">test site</a> and the
            <a href="https://github.com/thinkaz/glyph-extension-starter">starter template</a>.
          </p>
          <div class="docs-grid">
            {
              sdkDocs.map(doc => (
                <a href={`/docs/${doc.id}`} class="doc-card">
                  <span class="doc-icon" set:html={icons[doc.id] || ''} />
                  <div class="doc-card-content">
                    <h3>{doc.data.title}</h3>
                    <p>{descriptions[doc.id] || ''}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .docs-index {
    padding: 100px 0 80px;
    min-height: 100vh;
  }

  .docs-hero {
    margin-bottom: 48px;
  }

  .docs-hero h1 {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }

  .docs-hero p {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .docs-section {
    margin-bottom: 40px;
  }

  .docs-section h2 {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }

  .section-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: -8px;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .section-desc code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    background: var(--bg-surface);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent);
  }

  .section-desc a {
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .section-desc a:hover {
    border-bottom-color: var(--accent);
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .doc-card {
    display: flex;
    gap: 16px;
    padding: 20px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.2s,
      background 0.2s;
  }

  .doc-card:hover {
    border-color: var(--accent);
    background: var(--bg-surface-hover);
  }

  .doc-icon {
    font-size: 24px;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dim);
    border-radius: 10px;
  }

  .doc-card-content h3 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }

  .doc-card-content p {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .docs-index {
      padding: 80px 0 60px;
    }
    .docs-hero h1 {
      font-size: 28px;
    }
    .docs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
