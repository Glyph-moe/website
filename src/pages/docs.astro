---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { getCollection } from 'astro:content'

const allDocs = await getCollection('docs')
const sorted = allDocs.sort((a, b) => a.data.order - b.data.order)
const appDocs = sorted.filter(d => d.data.order <= 2)
const sdkDocs = sorted.filter(d => d.data.order >= 3)

const descriptions: Record<string, string> = {
  'getting-started': 'How to use the app, add extensions, browse novels, and customize the reader.',
  faq: 'Common questions about Glyph, extensions, privacy, and troubleshooting.',
  'sdk-overview': 'Architecture, quick start, project structure, and createSource basics.',
  'sdk-source-interface': 'Required and optional methods, types, and full examples.',
  'sdk-http': 'get, post, json, rate limiting, retries, interceptors, and error handling.',
  'sdk-helpers': 'Cheerio HTML parsing, pagination, cookies, and content rating.',
  'sdk-publishing': 'Building, hosting, versioning, testing, and deep links.',
}

const icons: Record<string, string> = {
  'getting-started': '📖',
  faq: '💬',
  'sdk-overview': '⚡',
  'sdk-source-interface': '🧩',
  'sdk-http': '🌐',
  'sdk-helpers': '🛠',
  'sdk-publishing': '🚀',
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Glyph Documentation" />
    <meta name="theme-color" content="#0E0E12" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Documentation — Glyph</title>
    <script is:inline>
      ;(function () {
        var t = localStorage.getItem('theme')
        if (t) document.documentElement.setAttribute('data-theme', t)
      })()
    </script>
  </head>
  <body>
    <Nav />

    <main class="docs-index">
      <div class="container">
        <div class="docs-hero">
          <h1>Documentation</h1>
          <p>Everything you need to use Glyph and build extensions.</p>
        </div>

        <section class="docs-section">
          <h2>Using Glyph</h2>
          <div class="docs-grid">
            {
              appDocs.map(doc => (
                <a href={`/docs/${doc.id}`} class="doc-card">
                  <span class="doc-icon">{icons[doc.id] || '📄'}</span>
                  <div class="doc-card-content">
                    <h3>{doc.data.title}</h3>
                    <p>{descriptions[doc.id] || ''}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </section>

        <section class="docs-section">
          <h2>Extension SDK</h2>
          <p class="section-desc">
            Build your own extensions with the <code>@glyph/sdk</code>. Start with the
            <a href="/template/example">test site</a> and the
            <a href="https://github.com/thinkaz/glyph-extension-starter">starter template</a>.
          </p>
          <div class="docs-grid">
            {
              sdkDocs.map(doc => (
                <a href={`/docs/${doc.id}`} class="doc-card">
                  <span class="doc-icon">{icons[doc.id] || '📄'}</span>
                  <div class="doc-card-content">
                    <h3>{doc.data.title}</h3>
                    <p>{descriptions[doc.id] || ''}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .docs-index {
    padding: 100px 0 80px;
    min-height: 100vh;
  }

  .docs-hero {
    margin-bottom: 48px;
  }

  .docs-hero h1 {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }

  .docs-hero p {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .docs-section {
    margin-bottom: 40px;
  }

  .docs-section h2 {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }

  .section-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: -8px;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .section-desc code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 13px;
    background: var(--bg-surface);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent);
  }

  .section-desc a {
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .section-desc a:hover {
    border-bottom-color: var(--accent);
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .doc-card {
    display: flex;
    gap: 16px;
    padding: 20px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.2s,
      background 0.2s;
  }

  .doc-card:hover {
    border-color: var(--accent);
    background: var(--bg-surface-hover);
  }

  .doc-icon {
    font-size: 24px;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dim);
    border-radius: 10px;
  }

  .doc-card-content h3 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }

  .doc-card-content p {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .docs-index {
      padding: 80px 0 60px;
    }
    .docs-hero h1 {
      font-size: 28px;
    }
    .docs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
