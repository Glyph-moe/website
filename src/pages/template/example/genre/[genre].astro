---
import MockSite from '../../../../layouts/MockSite.astro';
import { novels } from '../../../../data/mock-novels';

const allTags = [...new Set(novels.flatMap(n => n.tags))].sort();

export function getStaticPaths() {
  const tags = [...new Set(novels.flatMap(n => n.tags))];
  return tags.map(tag => ({
    params: { genre: tag.toLowerCase().replace(/\s+/g, '-') },
    props: { genre: tag },
  }));
}

const { genre } = Astro.props;
const slug = Astro.params.genre;
const filtered = novels.filter(n =>
  n.tags.some(t => t.toLowerCase().replace(/\s+/g, '-') === slug)
);
---

<MockSite title={genre}>
  <div class="genre-page">
    <div class="genre-header">
      <h1>{genre}</h1>
      <p class="genre-count">{filtered.length} novel{filtered.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="genre-tags">
      {allTags.map(tag => (
        <a
          href={`/template/example/genre/${tag.toLowerCase().replace(/\s+/g, '-')}`}
          class:list={['genre-chip', { active: tag === genre }]}
        >
          {tag}
        </a>
      ))}
    </div>

    <div class="genre-results">
      {filtered.map(novel => (
        <a href={`/template/example/novel/${novel.id}`} class="novel-card">
          <img class="novel-cover" src={novel.cover} alt={novel.title} loading="lazy" />
          <div class="novel-info">
            <h3 class="novel-title">{novel.title}</h3>
            <span class="novel-author">by {novel.author}</span>
            <div class="novel-tags">
              {novel.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="novel-meta">
              <span class={`status status-${novel.status.toLowerCase()}`}>{novel.status}</span>
              <span class="chapter-count">{novel.chapters.length} chapters</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</MockSite>

<style>
  .genre-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
  }
  .genre-header h1 { font-size: 24px; font-weight: 700; }
  .genre-count { font-size: 14px; color: var(--text-secondary); }

  .genre-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .genre-chip {
    font-size: 13px;
    padding: 5px 14px;
    border-radius: 20px;
    background: var(--tag-bg);
    color: var(--text-secondary);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .genre-chip:hover { background: var(--accent-light); color: var(--accent); text-decoration: none; }
  .genre-chip.active { background: var(--accent); color: white; }

  .genre-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .novel-card {
    display: flex;
    gap: 14px;
    padding: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .novel-card:hover { border-color: var(--accent); text-decoration: none; }

  .novel-cover {
    width: 70px;
    height: 105px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
    background: var(--tag-bg);
  }

  .novel-info { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .novel-title { font-size: 14px; font-weight: 600; line-height: 1.3; }
  .novel-author { font-size: 12px; color: var(--text-secondary); }

  .novel-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 4px; }
  .tag {
    font-size: 11px;
    padding: 2px 8px;
    background: var(--tag-bg);
    border-radius: 4px;
    color: var(--text-secondary);
  }

  .novel-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: auto;
    font-size: 12px;
  }
  .status {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
  }
  .status-ongoing { background: #dcfce7; color: #166534; }
  .status-completed { background: #dbeafe; color: #1e40af; }
  .status-hiatus { background: #fef3c7; color: #92400e; }
  .chapter-count { color: var(--text-secondary); }
</style>
