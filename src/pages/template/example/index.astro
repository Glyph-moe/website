---
import MockSite from '../../../layouts/MockSite.astro'
import { novels } from '../../../data/mock-novels'
---

<MockSite title="Home">
  <section class="hero-section">
    <h1>Welcome to NovelHaven</h1>
    <p class="hero-sub">Your home for web fiction. Free to read, forever.</p>
  </section>

  <section class="novel-grid-section">
    <div class="section-header">
      <h2>Popular Novels</h2>
      <span class="novel-count">{novels.length} novels</span>
    </div>

    <div class="novel-grid">
      {
        novels.map(novel => (
          <a href={`/template/example/novel/${novel.id}`} class="novel-card">
            <img class="novel-cover" src={novel.cover} alt={novel.title} loading="lazy" />
            <div class="novel-info">
              <h3 class="novel-title">{novel.title}</h3>
              <span class="novel-author">by {novel.author}</span>
              <div class="novel-tags">
                {novel.tags.slice(0, 3).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <div class="novel-meta">
                <span class={`status status-${novel.status.toLowerCase()}`}>{novel.status}</span>
                <span class="chapter-count">{novel.chapters.length} chapters</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="latest-updates">
    <div class="section-header">
      <h2>Latest Updates</h2>
    </div>
    <div class="update-list">
      {
        novels.slice(0, 4).map(novel => (
          <div class="update-item">
            <a href={`/template/example/novel/${novel.id}`} class="update-novel">
              {novel.title}
            </a>
            <a
              href={`/template/example/novel/${novel.id}/${novel.chapters[novel.chapters.length - 1].id}`}
              class="update-chapter"
            >
              {novel.chapters[novel.chapters.length - 1].title}
            </a>
            <span class="update-date">{novel.chapters[novel.chapters.length - 1].date}</span>
          </div>
        ))
      }
    </div>
  </section>
</MockSite>

<style>
  .hero-section {
    text-align: center;
    padding: 40px 0 32px;
  }
  .hero-section h1 {
    font-size: 28px;
    font-weight: 700;
  }
  .hero-sub {
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .section-header h2 {
    font-size: 18px;
    font-weight: 600;
  }
  .novel-count {
    font-size: 13px;
    color: var(--text-secondary);
  }

  .novel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }

  .novel-card {
    display: flex;
    gap: 14px;
    padding: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
  }
  .novel-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 12px rgba(99, 102, 241, 0.08);
    text-decoration: none;
  }

  .novel-cover {
    width: 80px;
    height: 120px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
    background: var(--tag-bg);
  }

  .novel-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .novel-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
  }
  .novel-author {
    font-size: 12px;
    color: var(--text-secondary);
  }

  .novel-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .tag {
    font-size: 11px;
    padding: 2px 8px;
    background: var(--tag-bg);
    border-radius: 4px;
    color: var(--text-secondary);
  }

  .novel-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: auto;
    font-size: 12px;
  }
  .status {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
  }
  .status-ongoing {
    background: #dcfce7;
    color: #166534;
  }
  .status-completed {
    background: #dbeafe;
    color: #1e40af;
  }
  .status-hiatus {
    background: #fef3c7;
    color: #92400e;
  }
  .chapter-count {
    color: var(--text-secondary);
  }

  /* Latest updates */
  .latest-updates {
    margin-top: 16px;
  }
  .update-list {
    display: flex;
    flex-direction: column;
  }
  .update-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
  }
  .update-novel {
    flex: 1;
    font-weight: 500;
    color: var(--text);
  }
  .update-chapter {
    color: var(--accent);
    font-size: 13px;
  }
  .update-date {
    color: var(--text-secondary);
    font-size: 12px;
    min-width: 80px;
    text-align: right;
  }
</style>
